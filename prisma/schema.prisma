generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Zip {
  id          Int           @id @default(autoincrement())
  zip         String        @unique
  city        String?
  state       String?
  ZipVertical ZipVertical[]

  @@index([zip])
}

model Vertical {
  id          Int           @id @default(autoincrement())
  name        String
  label       String
  group       String?
  ZipVertical ZipVertical[]

  @@unique([name, label])
}

model ZipVertical {
  id         Int      @id @default(autoincrement())
  zipId      Int
  verticalId Int
  zip        Zip      @relation(fields: [zipId], references: [id], onDelete: Cascade)
  vertical   Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([zipId, verticalId])
}
